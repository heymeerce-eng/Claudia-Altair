# ── Twilio WhatsApp ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886  # Número sandbox (o tu número de producción)

# ── Zoom (Server-to-Server OAuth) ───────────────────────────────────
# Crear en: marketplace.zoom.us > Develop > Build App > Server-to-Server OAuth
ZOOM_ACCOUNT_ID=xxxxxxxxxxxx
ZOOM_CLIENT_ID=xxxxxxxxxxxx
ZOOM_CLIENT_SECRET=xxxxxxxxxxxx

# ── Servidor ────────────────────────────────────────────────────────
PORT=5000
PUBLIC_URL=  # Se rellena automáticamente con ngrok si se deja vacío

# ── Miro ────────────────────────────────────────────────────────────
# Crear en: miro.com > Perfil > Settings > Apps > Your apps > Create new app
# Permisos: boards:read, boards:write
MIRO_API_TOKEN=

